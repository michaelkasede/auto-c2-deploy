version: '3.8'
services:
  decoy:
    image: {{ decoy_image | default('wordpress:latest') }}
    container_name: decoy_site
    restart: unless-stopped
    ports:
      - "8080:80"
    environment:
      - WORDPRESS_DB_HOST=unused
      - WORDPRESS_DB_USER=unused
      - WORDPRESS_DB_PASSWORD=unused
      - WORDPRESS_DB_NAME=unused
